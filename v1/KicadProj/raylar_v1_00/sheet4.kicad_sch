	)
	(text "Compatible PDM microphones (3.50 x 2.65 PDM)\n- T5838 (Invensense/TDK): Claims a max voltage of 1V8\n- IM66D130A: 7Hz low freq rolloff\n- IM68D121J: high sensitivity\n- IM69D129F: (suggested - 11Hz rolloff, low power)\n- IM70D122: high SNR, high sensitivity, 30Hz rolloff\n- SPH18R1LM4H-1: strictly 1V8 again"
		(exclude_from_sim no)
		(at 97.536 116.84 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "35e0c1e4-0294-4739-90ff-ac8261655db5")
	)
	(text "i2c address: 0011101b"
		(exclude_from_sim no)
		(at 234.188 38.1 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "450f8c03-e202-4892-a0c7-20993c0bfaea")
	)
	(text "MIC2-MIC6 are on shared CCK1. \nDisable CCK1 to place in low power mode.\n\nMIC2 - rising edge, MIC_SD1\nMIC3 - falling edge, MIC_SD1\nMIC4 - rising edge, MIC_SD2\nMIC5 - falling edge, MIC_SD2\nMIC6 - rising edge, MIC_SD3"
		(exclude_from_sim no)
		(at 97.282 77.47 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "a2e91b32-aa27-4d1f-9d80-aad7975f8bca")
	)
	(text "i2c address: 0011110b"
		(exclude_from_sim no)
		(at 236.474 90.424 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "a4ad7e68-3582-4999-9279-a99ab644aa94")
	)
	(text "MIC1 is on CCK0/SD0.\nDisable CCK0 to place in low power mode. \n\nThis MIC supports both MDF and ADF mode.\nUse this MIC in mono mode."
		(exclude_from_sim no)
		(at 97.79 40.64 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
